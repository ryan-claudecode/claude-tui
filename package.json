{
  "name": "claude-tui-app",
  "version": "0.1.0",
  "description": "Cross-platform terminal multiplexer for Claude Code sessions",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "tsc -b && electron-vite build && electron .",
    "dev:watch": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "typecheck": "tsc -b",
    "start": "electron .",
    "package": "npm run build && electron-builder --win dir",
    "package:installer": "npm run build && electron-builder --win nsis",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^5.2.2",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/diff": "^5.2.3",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
